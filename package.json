    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tweetnacl": "^1.0.3",
    "uuid": "^14.0.1",
    "viem": "^2.55.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "^6.19.2",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
