{
  "name": "freshmint-marketplace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma migrate deploy && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio",
    "wallets:create": "node scripts/create-platform-wallets.mjs",
    "wallets:deploy-safe": "node scripts/deploy-treasury-safe.mjs",
    "wallets:deploy-squads": "node scripts/deploy-treasury-squads.mjs",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@metaplex-foundation/mpl-core": "^1.10.0",
    "@metaplex-foundation/umi": "^1.5.1",
    "@metaplex-foundation/umi-bundle-defaults": "^1.5.1",
    "@metaplex-foundation/umi-signer-wallet-adapters": "^1.5.1",
    "@metaplex-foundation/umi-web3js-adapters": "^1.5.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@relayprotocol/relay-sdk": "^6.1.3",
    "@solana/web3.js": "^1.98.4",
    "@vercel/blob": "^2.6.1",
    "bs58": "^6.0.0",
    "dotenv": "^17.4.2",
    "jose": "^6.2.3",
    "next": "16.2.10",
    "otpauth": "^9.5.1",
    "pg": "^8.22.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tweetnacl": "^1.0.3",
    "uuid": "^14.0.1",
    "viem": "^2.55.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@safe-global/protocol-kit": "^8.0.4",
    "@sqds/multisig": "^2.1.4",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
