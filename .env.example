# Postgres (required for persistent mode). Local default matches docker-compose.yml
DATABASE_URL="postgresql://freshmint:freshmint@127.0.0.1:5433/freshmint?schema=public"

AUTH_SECRET="replace-with-a-long-random-secret"
NEXT_PUBLIC_APP_NAME="FreshMint Marketplace"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# testnet (default) | mainnet — flip when wallets are funded
NEXT_PUBLIC_CHAIN_MODE="testnet"
NEXT_PUBLIC_RELAY_SOURCE="freshmint.marketplace"

# Object storage (Vercel Blob). Without this, uploads go to public/uploads locally.
# BLOB_READ_WRITE_TOKEN=

# --- Platform fees (2.5% of sale: 1.5% treasury + 1% operator) ---
# Buyer pays listed price; seller receives 97.5%. Generate with: npm run wallets:create
# NEXT_PUBLIC_PLATFORM_TREASURY_ADDRESS="0x..."   # EVM Safe 2-of-3
# NEXT_PUBLIC_PLATFORM_TREASURY_SOLANA="..."      # Squads vault PDA
# NEXT_PUBLIC_PLATFORM_OPERATOR_ADDRESS="0x..."   # your EVM EOA (1%)
# NEXT_PUBLIC_PLATFORM_OPERATOR_SOLANA="..."      # your Solana pubkey (1%)

# --- EVM ERC-721 markets (one deploy per network) ---
# NEXT_PUBLIC_EVM_MARKET_ADDRESS_ETHEREUM="0x..."
# NEXT_PUBLIC_EVM_MARKET_ADDRESS_BASE="0x..."
# NEXT_PUBLIC_EVM_MARKET_ADDRESS_ARBITRUM="0x..."
# NEXT_PUBLIC_EVM_MARKET_ADDRESS_OPTIMISM="0x..."
# Legacy single-address fallback (maps to ethereum):
# NEXT_PUBLIC_EVM_MARKET_ADDRESS="0x..."

# EVM_RPC_URL_ETHEREUM="https://ethereum-sepolia-rpc.publicnode.com"
# EVM_RPC_URL_BASE="https://sepolia.base.org"
# EVM_RPC_URL_ARBITRUM="https://sepolia-rollup.arbitrum.io/rpc"
# EVM_RPC_URL_OPTIMISM="https://sepolia.optimism.io"
# Legacy:
# EVM_RPC_URL="https://ethereum-sepolia-rpc.publicnode.com"
# Optional server-side minter:
# EVM_MINTER_PRIVATE_KEY="0x..."

# --- Solana (Metaplex Core by default; set SOLANA_MINT_MODE=memo for attestation fallback) ---
NEXT_PUBLIC_SOLANA_CLUSTER="devnet"
# SOLANA_RPC_URL="https://api.devnet.solana.com"
# SOLANA_MINTER_SECRET_KEY="[1,2,3,...]"  # JSON byte array
# SOLANA_MINT_MODE="metaplex"
# SOLANA_REQUIRE_CONFIRM="false"
# RELAY_SOLANA_CHAIN_ID="792703809"

# ALLOW_DEMO_AUTH="true"
