# Required for Prisma. Local default points at prisma/dev.db (path is resolved
# from the project root by src/lib/env.ts if this var is missing at runtime).
DATABASE_URL="file:./dev.db"

# Session signing secret (min 16 chars)
AUTH_SECRET="replace-with-a-long-random-secret"

NEXT_PUBLIC_APP_NAME="FreshMint Marketplace"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_EVM_CHAIN="sepolia"
NEXT_PUBLIC_SOLANA_CLUSTER="devnet"

# Optional: point at a deployed FreshMintMarket.sol / Solana program
# NEXT_PUBLIC_EVM_MARKET_ADDRESS="0x..."
# NEXT_PUBLIC_SOLANA_PROGRAM_ID="..."

# Set true to allow demo persona login in production previews
# ALLOW_DEMO_AUTH="true"
